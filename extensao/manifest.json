{
    "manifest_version": 3,
    "name": "Hub de Ferramentas Dufrio",
    "short_name": "Hub Dufrio",
    "version": "1.6",
    "description": "Acesso rápido ao Hub de Ferramentas Dufrio e à Busca Ar.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://www.dufrio.com.br/*",
        "https://opensheet.elk.sh/*",
        "https://castaticstorage.blob.core.windows.net/*",
        "https://dufrio.operations.dynamics.com/*"
    ],
    "externally_connectable": {
        "matches": [
            "https://crf-two.github.io/*",
            "http://127.0.0.1:*/*",
            "http://localhost:*/*"
        ]
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Hub de Ferramentas Dufrio",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.dufrio.com.br/ar-condicionado*"
            ],
            "css": [
                "content.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.dufrio.com.br/checkout/cart/*"
            ],
            "css": [
                "cart.css"
            ],
            "js": [
                "cart.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://crf-two.github.io/*",
                "http://127.0.0.1:*/*",
                "http://localhost:*/*",
                "file:///*"
            ],
            "js": [
                "bridge.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        },
        {
            "matches": [
                "https://dufrio.operations.dynamics.com/*"
            ],
            "js": [
                "dynamics-auto-sort.js"
            ],
            "run_at": "document_idle",
            "all_frames": false,
            "world": "MAIN"
        }
    ]
}
